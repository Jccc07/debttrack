# Database — get from neon.tech (free tier)
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/debttrack?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-32-char-secret-here"

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# Gmail SMTP — use App Password, NOT your real Gmail password
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER="yourname@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron security — any random string
CRON_SECRET="another-random-secret-here"
